    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "module": "ES2020",
        "target": "ES2021",
        "moduleResolution": "Node",
        "allowSyntheticDefaultImports": true,
        "baseUrl": "./src",
        "rootDir": "./src",
        "outDir": "./scripts"
    },
    "exclude": ["node_modules"],
    "include": ["src"]
}